# ============================================================
# Ubatik RAG Histologia — Variables de Entorno
# ============================================================
# Copia este archivo como .env y completa los valores
# cp .env.example .env

# --- LLM Principal (Gemini) ---
GOOGLE_API_KEY=tu-api-key-de-gemini

# --- LLM Alternativo / Evaluador (Groq) ---
GROQ_API_KEY=tu-api-key-de-groq

# --- Hugging Face (modelos CLIP, ImageBIND, UNI) ---
HF_TOKEN=tu-token-huggingface-read

#  La base de datos ahora se maneja localmente
# # --- Qdrant Cloud --- 
# QDRANT_URL=https://tu-cluster.qdrant.cloud
# QDRANT_API_KEY=tu-qdrant-api-key

# --- LangSmith (Opcional — Observabilidad) ---
LANGSMITH_API_KEY=lsv2_pt_...
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=ubatik-rag-histologia-g3

# --- Servidor ---
PORT=10010
HOST=0.0.0.0
