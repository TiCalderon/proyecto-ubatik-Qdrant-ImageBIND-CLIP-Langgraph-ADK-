# ─── Secrets y entorno ───────────────────────────────────────────────
.env
.env.local
*.env

# ─── Python ──────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
*.egg
.eggs/

# ─── Entornos virtuales ──────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ─── Jupyter Notebooks ───────────────────────────────────────────────
.ipynb_checkpoints/
*-checkpoint.ipynb

# ─── Datos (no versionar contenido pesado o sensible) ────────────────
