data/pdfs/*.pdf
data/imagenes_extraidas/
data/*.json

# ─── Outputs y trazas generadas ──────────────────────────────────────
outputs/
trayectoria_histologia.json
trayectoria_qdrant.json
trayectoria_neo4j.json
temario_histologia.json
logs/

# ─── Modelos descargados (cache de HuggingFace) ──────────────────────
.cache/
hf_cache/
*.bin
*.safetensors
*.pt
*.pth

# ─── IDEs ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

