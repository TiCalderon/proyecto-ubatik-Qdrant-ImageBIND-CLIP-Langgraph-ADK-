# ==============================================================================
# CETEC RAG Histología — Variables de entorno
# ==============================================================================
# Para uso local (futuro):
#   cp .env.example .env
#   Completar los valores con tus claves
#
# Para Colab: NO usar este archivo. Configurar los mismos nombres en
# "Secrets" del panel lateral de Colab.
# ==============================================================================

# ── Google Gemini (REQUERIDO) ────────────────────────────────────────────────
# LLM principal y análisis visual de imágenes.
# Obtener en: https://aistudio.google.com/apikey
GOOGLE_API_KEY=tu-api-key-de-gemini

# ── Qdrant Cloud (REQUERIDO) ─────────────────────────────────────────────────
# Base vectorial. Crear cluster gratuito en https://cloud.qdrant.io/
QDRANT_URL=https://tu-cluster.region.gcp.cloud.qdrant.io:6333
QDRANT_KEY=tu-api-key-de-qdrant

# ── Hugging Face (REQUERIDO) ─────────────────────────────────────────────────
# Necesario para descargar CONCH (modelo gated de MahmoodLab).
# 1. Aceptar términos en https://huggingface.co/MahmoodLab/conch
# 2. Generar token en https://huggingface.co/settings/tokens
HF_TOKEN=tu-token-de-huggingface

# ── Groq ────────────────────────────────────────────────
# LLM Llama-4-Scout. Plan de migración desde Gemini.
# Obtener en: https://console.groq.com/keys
GROQ_API_KEY=tu-api-key-de-groq

# ── LangSmith (OPCIONAL) ─────────────────────────────────────────────────────
# Observabilidad de trazas LangGraph.
# Obtener en: https://smith.langchain.com/
LANGSMITH_API_KEY=tu-api-key-de-langsmith
LANGSMITH_PROJECT=CETEC_g2
